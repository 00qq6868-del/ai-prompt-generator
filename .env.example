# ============================================================
# AI 提示词生成器 — 环境变量配置
# 复制此文件为 .env.local 并填入你的 API Key
# 至少需要配置一个 Provider 才能使用
# ============================================================

# ── OpenAI (GPT-4o / GPT-4o-mini / o3 / o4-mini) ──────────
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Anthropic (Claude Opus / Sonnet / Haiku) ───────────────
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Google (Gemini 2.5 Pro / 2.0 Flash) ───────────────────
# 获取地址: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Groq · Meta Llama (Llama 3.3 70B / 3.1 8B) ───────────
# 获取地址: https://console.groq.com/keys
# 国内可访问，速度极快，有免费额度
GROQ_API_KEY=

# ── xAI (Grok-3 / Grok-3 Mini) ────────────────────────────
# 获取地址: https://console.x.ai/
XAI_API_KEY=

# ── Mistral AI (Mistral Large / Small) ─────────────────────
# 获取地址: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# ── 深度求索 DeepSeek (V3 / R1) ───────────────────────────
# 获取地址: https://platform.deepseek.com/api_keys
# 国内直连，价格极低
DEEPSEEK_API_KEY=

# ── 智谱AI GLM-4 Plus ──────────────────────────────────────
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# ── 月之暗面 Kimi (moonshot-v1) ───────────────────────────
# 获取地址: https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# ── 阿里巴巴 通义千问 Qwen (Max / Turbo) ──────────────────
# 获取地址: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=

# ── 百度 文心一言 ERNIE 4.0 ────────────────────────────────
# 获取地址: https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
# 需要同时配置 API_KEY 和 SECRET_KEY 两个字段
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ── 模型注册表自动更新（可选）─────────────────────────────
# 留空时使用内置模型列表（已包含所有主流模型）
# 如需自动获取最新模型，请填入返回 ModelInfo[] JSON 的公开 HTTPS URL
# MODELS_REGISTRY_URL=https://raw.githubusercontent.com/YOUR_USERNAME/ai-models-registry/main/models.json

# ── Ollama 本地模型（完全免费，无需 API Key）────────────────
# 安装 Ollama: https://ollama.com
# 安装后下载模型（选一个即可）:
#   ollama pull llama3.2      (英文, 2GB)
#   ollama pull qwen2.5:7b    (中文优先, 4.7GB)
#   ollama pull mistral       (英文, 4.1GB)
# 默认地址无需修改，Ollama 安装后自动在此端口运行
OLLAMA_BASE_URL=http://localhost:11434

# ── 免费基础防护 / Free basic safeguards ─────────────────────
# 生成接口限流：默认每个 IP 每分钟 20 次
GENERATE_RATE_LIMIT_MAX=20
GENERATE_RATE_LIMIT_WINDOW_MS=60000
GENERATE_MAX_INPUT_CHARS=12000
GENERATE_MAX_TOKENS=4096

# 中转站探测限流：默认每个 IP 每 10 分钟 30 次
PROBE_RATE_LIMIT_MAX=30
PROBE_RATE_LIMIT_WINDOW_MS=600000

# 监控数据：本地开发默认写入 .analytics；Vercel 上默认只接受并输出计数
# 如果有免费 Webhook/日志服务，可填入 HTTPS 地址做持久化
ANALYTICS_RATE_LIMIT_MAX=120
ANALYTICS_RATE_LIMIT_WINDOW_MS=60000
ANALYTICS_WEBHOOK_URL=

# ── 持久化与反馈闭环 / Persistence and feedback loop ──────────
# 留空时自动使用项目根目录 .local-data/ 本机JSON存储；配置后写入PostgreSQL。
DATABASE_URL=
REDIS_URL=

# 用户反馈/测试数据只写自有仓库或私有数据仓库；14个外部提示词仓库只读同步，不写用户数据。
# GitHub token 必须放服务端环境变量，绝不要写进前端或提交到仓库。
GITHUB_DATA_TOKEN=
GITHUB_DATA_REPO=00qq6868-del/ai-prompt-generator
GITHUB_DATA_BRANCH=main
PROMPT_FEEDBACK_GITHUB_TOKEN=
PROMPT_FEEDBACK_GITHUB_REPO=00qq6868-del/ai-prompt-generator
PROMPT_FEEDBACK_GITHUB_BRANCH=main

# 未来接入对象存储时使用；真实照片/生成图不直接提交 GitHub。
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# Docker Compose 本地完整架构：
#   docker compose up --build
# 会启动 web + postgres + redis + Python worker，并自动执行 database/schema.sql。

# ── 线上真实链路测试 / Production smoke test ────────────────
PRODUCTION_BASE_URL=https://www.myprompt.asia
# 本地没有真实 key 时可先跳过生成，只测首页/模型/analytics
SMOKE_SKIP_GENERATE=1
