{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist-tests",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false,
    "incremental": false,
    "types": ["node"]
  },
  "include": [
    "src/app/api/v3/**/*.ts",
    "src/comparison/**/*.ts",
    "src/domain/**/*.ts",
    "src/prompt-engines/**/*.ts",
    "src/quality/**/*.ts",
    "src/safety/**/*.ts",
    "src/server/**/*.ts",
    "src/test-site-client/**/*.ts",
    "tests/*.ts"
  ],
  "exclude": ["node_modules", "tests/e2e", "dist-tests"]
}
