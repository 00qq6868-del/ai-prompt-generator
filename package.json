{
  "name": "ai-prompt-generator",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev --hostname 0.0.0.0",
    "dev:https": "next dev --experimental-https --hostname 0.0.0.0",
    "build": "node scripts/build-next-clean.cjs",
    "start": "next start --hostname 0.0.0.0",
    "start:e2e": "node scripts/start-e2e-server.cjs",
    "lint": "next lint",
    "setup:icons": "node scripts/generate-icons.js",
    "electron:dev": "electron .",
    "desktop:verify": "node scripts/verify-desktop-standalone.cjs",
    "electron:build": "npm run build && npm run desktop:verify && electron-builder --win --config.win.signAndEditExecutable=false --publish never",
    "electron:build:mac": "npm run build && npm run desktop:verify && electron-builder --mac --publish never",
    "electron:build:linux": "npm run build && npm run desktop:verify && electron-builder --linux --publish never",
    "electron:build:all": "npm run build && npm run desktop:verify && electron-builder --win --mac --linux --config.win.signAndEditExecutable=false --publish never",
    "electron:publish": "npm run build && npm run desktop:verify && electron-builder --win --config.win.signAndEditExecutable=false --publish always",
    "smoke:prod": "node scripts/production-smoke.cjs",
    "sources:gpt-image2": "node scripts/sync-gpt-image2-sources.cjs",
    "sources:prompt-library": "node scripts/sync-prompt-library-sources.cjs",
    "sources:github-projects": "node scripts/sync-github-project-tracker.cjs",
    "sources:all": "npm run sources:gpt-image2 && npm run sources:prompt-library && npm run sources:github-projects",
    "data:validate": "node scripts/validate-feedback-data.cjs data",
    "test:gpt-image2:real": "node scripts/real-gpt-image2-quality-test.cjs",
    "test:gpt-image2:panel": "node scripts/gpt-image2-live-review-panel.cjs",
    "memory:boot": "node scripts/update-memory-checkpoint.cjs --boot",
    "memory:checkpoint": "node scripts/update-memory-checkpoint.cjs",
    "test:secure-prompt": "python scripts/secure_prompt_quality_test.py",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:quality": "npx playwright test tests/e2e/quality.spec.ts --project=chromium"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google/generative-ai": "^0.24.0",
    "axios": "^1.15.0",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.577.0",
    "next": "^14.2.35",
    "openai": "^4.104.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.6.0",
    "sharp": "^0.33.5",
    "web-vitals": "^5.2.0"
  },
  "optionalDependencies": {
    "electron-updater": "^6.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "electron": "^31.7.0",
    "electron-builder": "^26.8.0",
    "localtunnel": "^2.0.2",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.0"
  },
  "build": {
    "appId": "com.ai-prompt-generator.app",
    "productName": "AI提示词生成器",
    "copyright": "Copyright © 2025",
    "artifactName": "AI-Prompt-Generator-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist-electron"
    },
    "publish": {
      "provider": "github",
      "owner": "00qq6868-del",
      "repo": "ai-prompt-generator"
    },
    "files": [
      "electron/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app",
        "filter": [
          "**/*",
          "!node_modules/.cache/**",
          "!node_modules/@swc/**",
          "!node_modules/typescript/**",
          "!node_modules/eslint/**"
        ]
      },
      {
        "from": ".next/static",
        "to": "app/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "app/public",
        "filter": [
          "**/*",
          "!*.map"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "electron/preload.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon-512.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "public/icons/icon-512.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon-512.png",
      "category": "Utility"
    },
    "dmg": {
      "title": "AI提示词生成器",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "artifactName": "AI-Prompt-Generator-Setup-${version}-${os}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI提示词生成器",
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052"
    },
    "portable": {
      "artifactName": "AI-Prompt-Generator-Portable-${version}-${os}-${arch}.${ext}"
    }
  }
}
